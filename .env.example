# Database (PostgreSQL for Render and recommended for local dev)
# Local Docker: docker run -e POSTGRES_PASSWORD=postgres -p 5432:5432 postgres
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/postgres"

# NextAuth (required for production)
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="dev-secret-change-in-production"

# Optional: for AI and cron features
# OPENAI_API_KEY="sk-..."
# CRON_SECRET="random-secret-for-cron-endpoints"

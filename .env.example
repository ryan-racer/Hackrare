# Database (PostgreSQL for Render and recommended for local dev)
# Local Docker: docker run -e POSTGRES_PASSWORD=postgres -p 5432:5432 postgres
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/postgres"

# NextAuth (required for production)
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="dev-secret-change-in-production"

# Auth0 (required for Auth0 SDK)
# Get these from your Auth0 Application settings. Add to .env.local (never commit secrets).
# In Auth0 Dashboard → Application → Your App → Settings, set:
#   Application Type: Regular Web Application
#   Token Endpoint Auth Method: Post
#   Allowed Callback URLs: http://localhost:3000/auth/callback
#   Allowed Logout URLs: http://localhost:3000
APP_BASE_URL="http://localhost:3000"
AUTH0_DOMAIN="dev-0zf27304qvkezpsa.us.auth0.com"
AUTH0_CLIENT_ID="jeDRSFLGzC6V8nuKyjmvOYIsLZgBMzRu"
AUTH0_CLIENT_SECRET=""
# 64 character random string; generate with: openssl rand -hex 32
AUTH0_SECRET=""

# Optional: for AI and cron features
# OPENAI_API_KEY="sk-..."
# CRON_SECRET="random-secret-for-cron-endpoints"

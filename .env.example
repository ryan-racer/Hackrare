# Database (PostgreSQL for Render and local dev)
# Local Docker: docker run -e POSTGRES_PASSWORD=postgres -p 5432:5432 postgres
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Auth0 (required for login)
# From Auth0 Dashboard → Application → Settings
# Set Allowed Callback URLs: https://your-app.onrender.com/auth/callback (and http://localhost:3000/auth/callback for local)
# Set Allowed Logout URLs: https://your-app.onrender.com (and http://localhost:3000 for local)
APP_BASE_URL=http://localhost:3000
AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_CLIENT_ID=your_client_id
AUTH0_CLIENT_SECRET=
# 64 chars; generate with: openssl rand -hex 32
AUTH0_SECRET=

# Optional: legacy NextAuth (only if using /api/auth/register)
# NEXTAUTH_URL=http://localhost:3000
# NEXTAUTH_SECRET=

# Optional: AI and cron
# OPENAI_API_KEY=
# CRON_SECRET=

# Optional: SMS (Twilio)
# From Twilio Console → Phone Numbers
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_TEXT_FROM=+15551234567

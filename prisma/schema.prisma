generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  passwordHash  String?
  role          String    // "patient" | "doctor"
  emailVerified DateTime?
  image         String?
  phone         String?   @unique
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Patient onboarding (null = not completed)
  onboardingCompletedAt DateTime?
  dateOfBirth           DateTime?
  heightCm              Int?
  weightKg              Float?
  pcpName               String?
  pcpCity               String?
  pcpState              String?
  currentDiagnoses      String?   // JSON array of strings
  currentMedications    String?   // JSON array of { name, dose?, frequency? }
  allergies             String?

  accounts       Account[]
  sessions       Session[]
  patientLinks   PatientDoctor[] @relation("Patient")
  doctorLinks    PatientDoctor[] @relation("Doctor")
  checkIns       CheckIn[]       @relation("PatientCheckIns")
  journalAssignments JournalAssignment[]
  aiInsights       AIInsight[]
  generalChats     GeneralChat[]
  diagnoses        Diagnosis[]
  clinicianReports ClinicianReport[]
  alerts           Alert[]
}

model AIInsight {
  id         String   @id @default(cuid())
  patientId  String
  content    String
  summaryIds String?  // JSON array of checkInSummary ids used
  createdAt  DateTime @default(now())

  patient User @relation(fields: [patientId], references: [id], onDelete: Cascade)
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model PatientDoctor {
  id        String   @id @default(cuid())
  patientId String
  doctorId  String
  createdAt DateTime @default(now())

  patient User @relation("Patient", fields: [patientId], references: [id], onDelete: Cascade)
  doctor User @relation("Doctor", fields: [doctorId], references: [id], onDelete: Cascade)

  @@unique([patientId, doctorId])
}

model JournalTemplate {
  id           String   @id @default(cuid())
  name         String
  condition    String
  schedule     String?  // e.g. "daily", "0 9 * * *" cron
  questionFlow String   // JSON
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  assignments JournalAssignment[]
  checkIns    CheckIn[]
}

model JournalAssignment {
  id         String   @id @default(cuid())
  patientId  String
  templateId String
  frequencyOverride String? // optional override
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())

  patient  User             @relation(fields: [patientId], references: [id], onDelete: Cascade)
  template JournalTemplate  @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@unique([patientId, templateId])
}

model CheckIn {
  id         String   @id @default(cuid())
  patientId  String
  templateId String
  scheduledAt DateTime
  status     String   // "pending" | "in_progress" | "completed"
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  patient  User             @relation("PatientCheckIns", fields: [patientId], references: [id], onDelete: Cascade)
  template JournalTemplate  @relation(fields: [templateId], references: [id], onDelete: Cascade)
  messages CheckInMessage[]
  response CheckInResponse?
  summary  CheckInSummary?
}

model CheckInMessage {
  id        String   @id @default(cuid())
  checkInId String
  role      String   // "assistant" | "user"
  content   String
  createdAt DateTime @default(now())

  checkIn CheckIn @relation(fields: [checkInId], references: [id], onDelete: Cascade)
}

model CheckInResponse {
  id        String   @id @default(cuid())
  checkInId String   @unique
  rawData   String   // JSON object of answers
  updatedAt DateTime @updatedAt

  checkIn CheckIn @relation(fields: [checkInId], references: [id], onDelete: Cascade)
}

model CheckInSummary {
  id             String   @id @default(cuid())
  checkInId      String   @unique
  medicalSummary String
  modelUsed      String?
  createdAt      DateTime @default(now())

  checkIn CheckIn @relation(fields: [checkInId], references: [id], onDelete: Cascade)
}

model GeneralChat {
  id            String   @id @default(cuid())
  patientId     String
  title         String?
  extractedData String?  // JSON — AI-extracted structured symptoms/events
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  patient  User                 @relation(fields: [patientId], references: [id], onDelete: Cascade)
  messages GeneralChatMessage[]
}

model GeneralChatMessage {
  id        String   @id @default(cuid())
  chatId    String
  role      String   // "user" | "assistant"
  content   String
  createdAt DateTime @default(now())

  chat GeneralChat @relation(fields: [chatId], references: [id], onDelete: Cascade)
}

// ── Agent 3: Rare Disease Evidence Pack ──────────────────────────────────────

model Diagnosis {
  id           String   @id @default(cuid())
  patientId    String
  diseaseLabel String   // human-readable name
  diseaseId    String?  // e.g. ORPHA:123 or GARD:0001234
  confirmed    Boolean  @default(false)
  working      Boolean  @default(true)  // "working diagnosis"
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  patient           User               @relation(fields: [patientId], references: [id], onDelete: Cascade)
  checkinTemplates  CheckinTemplate[]
}

model ClinicianReport {
  id                String   @id @default(cuid())
  patientId         String
  generatedAt       DateTime @default(now())
  periodStart       DateTime
  periodEnd         DateTime
  reportMd          String   // full markdown evidence pack
  hpoTerms          String   // JSON: [{label, hpoId?, verified}]
  candidateConditions String  // JSON: [{name, orphaCode?, matchedTerms, discriminators, references}]
  checkinsUsed      Int      @default(0)

  patient User @relation(fields: [patientId], references: [id], onDelete: Cascade)
}

model Alert {
  id        String   @id @default(cuid())
  patientId String
  severity  String   // "info" | "watch" | "urgent"
  title     String
  message   String
  resolved  Boolean  @default(false)
  createdAt DateTime @default(now())

  patient User @relation(fields: [patientId], references: [id], onDelete: Cascade)
}

// ── Agent 4: Disease-Specific Templates ──────────────────────────────────────

model CheckinTemplate {
  id           String   @id @default(cuid())
  diagnosisId  String
  templateJson String   // renderable form definition JSON
  cadence      String   @default("daily") // "daily" | "weekly" | "flare"
  createdAt    DateTime @default(now())

  diagnosis Diagnosis @relation(fields: [diagnosisId], references: [id], onDelete: Cascade)
}
